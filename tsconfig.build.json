{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/poc/**",
    "src/**/*.test.ts",
    "test/**",
    "examples/**",
    "node_modules",
    "dist"
  ]
}
