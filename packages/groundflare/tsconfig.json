{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "groundflare-estimate": ["../estimate/src/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/poc/**",
    "examples/**",
    // Bun-runtime adapter sources ship as raw text to the VPS and are
    // executed by `bun run` there — not by Node. They import `bun:sqlite`
    // and reference BodyInit/BufferSource from Bun's type surface, which
    // the Node tsconfig can't satisfy. Behaviour is verified by the Bun
    // conformance suites (`test/bun/**` under `bun test`, and
    // `test/conformance/**` under vitest against the Node-side parity
    // adapters) — see design/testing.md.
    "src/runtime/bun/adapters/kv.ts",
    "src/runtime/bun/adapters/d1.ts",
    "src/runtime/bun/adapters/r2.ts",
    "src/runtime/bun/adapters/sigv4.ts",
    // workerd R2 adapter Worker — runs inside workerd, references DOM
    // BodyInit + transitively imports the Bun-runtime sigv4 (which uses
    // BufferSource). Behaviour verified by the L2 spawn-workerd
    // integration tests + L3 e2e tests against real SeaweedFS.
    "src/runtime/workerd/r2/adapter.worker.ts",
    "test/bun/**"
  ]
}
