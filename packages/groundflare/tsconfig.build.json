{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // Dev (tsconfig.json) maps `groundflare-estimate` straight to its
    // source tree so `npm run dev` and vitest don't need a built sibling.
    // At build time we want the published dist/index.d.ts (resolved via
    // node_modules symlink) so tsc doesn't drag estimate's source
    // into groundflare's tarball. Clear the mapping and ensure estimate
    // is built first — see root package.json `build` script.
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/poc/**",
    "src/**/*.test.ts",
    "test/**",
    "examples/**",
    "node_modules",
    "dist",
    // Bun-runtime adapter sources are shipped as raw text (see
    // scripts/copy-bun-adapters.mjs) and executed by `bun run` on the
    // VPS, not compiled to .js. Keep them out of tsc so the build
    // succeeds without bun-types coexisting with @types/node. The
    // shared KV/D1 conformance spec (test/conformance/**) + the
    // Bun-native suite (test/bun/**) cover behavioural correctness.
    "src/runtime/bun/adapters/kv.ts",
    "src/runtime/bun/adapters/d1.ts",
    "src/runtime/bun/adapters/r2.ts",
    "src/runtime/bun/adapters/sigv4.ts"
  ]
}
