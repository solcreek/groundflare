{
  "name": "groundflare-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for the groundflare CLI and create-groundflare-app scaffold.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solcreek/groundflare.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "npm run check --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:bun": "npm run test:bun -w groundflare",
    "test:e2e": "npm run test:e2e -w groundflare",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.0"
  }
}
